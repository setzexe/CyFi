# -----------------------------
# CyFi .gitignore (starter)
# -----------------------------

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables / secrets
.env
.env.*
!.env.example

# Node / JavaScript
node_modules/
dist/
build/
coverage/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
cyfi_local.db

# Generic cache/temp
.cache/
.temp/
.tmp/
*.tmp

# Edit this later when you actually know what files/folders you want to ignore in your project